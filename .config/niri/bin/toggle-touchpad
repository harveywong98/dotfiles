#!/usr/bin/env python3
from pathlib import Path
import json
import subprocess
import sys

config_path = Path.home() / ".config/niri/config.kdl"
text = config_path.read_text()
start = text.find("    touchpad {\n")
if start == -1:
    print("Could not find the touchpad block in config.kdl", file=sys.stderr)
    sys.exit(1)

end = text.find("\n    }", start)
if end == -1:
    print("Could not find the end of the touchpad block in config.kdl", file=sys.stderr)
    sys.exit(1)
end += len("\n    }")

block = text[start:end]
lines = block.splitlines()

current_state = "on"
off_line = None
for i, line in enumerate(lines):
    stripped = line.strip()
    if stripped == "off":
        current_state = "off"
        off_line = i
        break
    if stripped == "// off":
        current_state = "on"
        off_line = i
        break

if current_state == "off":
    lines[off_line] = lines[off_line].replace("off", "// off", 1)
    new_state = "on"
else:
    if off_line is None:
        insert_at = 1 if len(lines) > 1 else len(lines)
        lines.insert(insert_at, "        off")
    else:
        lines[off_line] = lines[off_line].replace("// off", "off", 1)
    new_state = "off"

new_block = "\n".join(lines)
new_text = text[:start] + new_block + text[end:]
config_path.write_text(new_text)

summary = f"Touchpad {'Enabled' if new_state == 'on' else 'Disabled'}"
payload = json.dumps({
    "title": summary,
})
subprocess.run([
    "qs", "ipc", "-c", "noctalia-shell", "call", "toast", "send", payload
], check=False)
print(summary)
